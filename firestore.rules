rules_version = '2';

// SamiSphere Firestore security rules (doc 01 §7).
//   - Anyone may CREATE a registration (students sign up).
//   - Only the logged-in teacher may READ / EDIT / DELETE registrations.
//   - Only the logged-in teacher may ADD / EDIT / HIDE courses.
//   - Anyone may READ AVAILABLE courses (to fill the student dropdown).
service cloud.firestore {
  match /databases/{database}/documents {

    // The single teacher (Samira). Pinning her email means that even if someone
    // self-creates an auth account, they do NOT get teacher access — only her
    // account does. (Her email can't be re-registered: it's already taken.)
    function isTeacher() {
      return request.auth != null
        && request.auth.token.email == 'samira@samisphere.com';
    }

    // Courses / time slots.
    match /courses/{courseId} {
      // Public reads are limited to available slots: an anonymous query must be
      // constrained to status == "available" (which the student form does), so
      // hidden slots never reach the public. The teacher may read everything.
      allow read: if resource.data.status == 'available' || isTeacher();
      // Only the teacher may add / edit / hide. Optional fields, when present,
      // must be well-typed: `meetingLink` a string; `price` a number;
      // `priceUnit` one of hour/month; `currency` one of RUB/USD. Absent fields
      // (old courses) stay valid.
      allow create, update: if isTeacher()
        && (!('meetingLink' in request.resource.data)
          || request.resource.data.meetingLink is string)
        && (!('price' in request.resource.data)
          || request.resource.data.price is number)
        && (!('priceUnit' in request.resource.data)
          || request.resource.data.priceUnit in ['hour', 'month'])
        && (!('currency' in request.resource.data)
          || request.resource.data.currency in ['RUB', 'USD']);
      allow delete: if isTeacher();
    }

    // Registrations.
    match /registrations/{registrationId} {
      // Anyone may create a registration, with basic shape validation to limit
      // junk: non-empty first/last name + email, plus course and time strings.
      allow create: if request.resource.data.firstName is string
        && request.resource.data.firstName.size() > 0
        && request.resource.data.lastName is string
        && request.resource.data.lastName.size() > 0
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.course is string
        && request.resource.data.time is string
        // Optional comment: when present, a string of at most 500 characters.
        && (!('comment' in request.resource.data)
          || (request.resource.data.comment is string
            && request.resource.data.comment.size() <= 500));
      // Only the teacher may read / edit / delete.
      allow read, update, delete: if isTeacher();
    }

    // Anything not matched above is denied by default.
  }
}
