# Telegram notification credentials for the Cloud Function.
# PLACEHOLDERS — leave empty until Phase 11 (Testing & go-live).
#
# To fill in (Phase 11):
#   1. Create the bot via @BotFather in Telegram → copy the bot token.
#   2. Have Samira start a chat with the bot, then get her numeric chat ID
#      (e.g. message the bot and read it from
#      https://api.telegram.org/bot<TOKEN>/getUpdates).
#   3. Copy this file to functions/.env and paste the real values below.
#      functions/.env is git-ignored and is uploaded with the function on deploy.
# TELEGRAM_CHAT_ID may be a single ID or a comma-separated list of recipients
# (e.g. admin + teacher): TELEGRAM_CHAT_ID=111111111,222222222
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
