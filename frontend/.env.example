# Firebase web config — template. Copy to `.env` and fill in real values.
# Get these from: Firebase Console → Project settings → Your apps → Web app → SDK setup.
# `.env` is git-ignored; this `.env.example` IS committed so others know what's needed.
PUBLIC_FIREBASE_API_KEY=your-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef0123456789
PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
